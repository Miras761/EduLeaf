rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: quizzes
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required, 1-100 chars)
    //   - creatorId: string (required, immutable, must match auth.uid)
    //   - questions: list of objects (required, max 50 questions)
    //     - question: string (required, 1-500 chars)
    //     - options: list of strings (required, exactly 4 options, each 1-100 chars)
    //     - correctOptionIndex: number (required, 0-3)
    //   - createdAt: timestamp (required, immutable)
    //   - isPublic: boolean (optional)
    //   - creatorName: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.creatorId;
    }

    function uidUnchanged() {
      return !('creatorId' in request.resource.data) ||
        request.resource.data.creatorId == request.auth.uid;
    }

    function uidNotModified() {
      return !('creatorId' in request.resource.data) ||
        request.resource.data.creatorId == resource.data.creatorId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // Domain Validators
    function isValidQuiz() {
      let data = request.resource.data;
      return hasRequiredFields(['title', 'creatorId', 'questions', 'createdAt']) &&
             hasOnlyAllowedFields(['title', 'creatorId', 'questions', 'createdAt', 'isPublic', 'creatorName']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             data.creatorId is string && data.creatorId.size() > 0 &&
             data.createdAt is timestamp &&
             data.questions is list && data.questions.size() > 0 && data.questions.size() <= 50 &&
             (!('isPublic' in data) || data.isPublic is bool) &&
             (!('creatorName' in data) || (data.creatorName is string && data.creatorName.size() <= 100));
             // Note: Deep array validation is limited in rules, but we enforce size and type.
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /quizzes/{quizId} {
      // Anyone can read quizzes to play them
      allow read: if true;
      
      // Only authenticated users can create quizzes, and they must own them
      allow create: if isAuthenticated() && 
                    isValidQuiz() && 
                    uidUnchanged();
                    
      // Only the creator can update or delete their quiz
      allow update: if isDocOwner() && 
                    isValidQuiz() && 
                    uidNotModified() &&
                    request.resource.data.createdAt == resource.data.createdAt;
                    
      allow delete: if isDocOwner();
    }
  }
}
